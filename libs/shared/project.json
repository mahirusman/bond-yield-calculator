{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@bond-calculator/shared",
  "projectType": "library",
  "root": "libs/shared",
  "sourceRoot": "libs/shared/src",
  "tags": ["scope:shared", "type:domain"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p libs/shared/tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config vitest.config.ts",
        "cwd": "libs/shared"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint libs/shared --ext .ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/shared/tsconfig.json --noEmit"
      }
    }
  }
}
