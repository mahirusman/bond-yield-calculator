# Backend
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=debug
JSON_BODY_LIMIT=100kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Frontend (prefix with VITE_ to expose to client)
VITE_API_URL=http://localhost:3001/api/v1

# Docker compose frontend URL
# VITE_API_URL=/api/v1

# Sanity Studio CMS
SANITY_STUDIO_PROJECT_ID=demo
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOST=bond-yield-calculator-cms

# Frontend Sanity content consumption, when content reads are added
VITE_SANITY_PROJECT_ID=demo
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-01-01
