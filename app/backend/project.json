{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@bond-calculator/backend",
  "projectType": "application",
  "root": "app/backend",
  "sourceRoot": "app/backend/src",
  "implicitDependencies": ["@bond-calculator/shared"],
  "tags": ["scope:backend", "type:api"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["@bond-calculator/shared:build"],
      "options": {
        "command": "npm run dev --workspace=app/backend"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["@bond-calculator/shared:build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build --workspace=app/backend"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm run start --workspace=app/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["@bond-calculator/shared:build"],
      "options": {
        "command": "vitest run --config vitest.config.ts",
        "cwd": "app/backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint app/backend --ext .ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p app/backend/tsconfig.json --noEmit"
      }
    }
  }
}
